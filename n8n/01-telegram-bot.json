    {
      "parameters": {
        "functionCode": "let text = '';\nconst input = $input.first().json;\nif (input.message) {\n  text = input.message;\n} else if (input.error) {\n  text = '❌ Error: ' + input.error;\n} else if (input.raw) {\n  text = input.raw;\n} else if (typeof input === 'string') {\n  text = input;\n} else {\n  text = JSON.stringify(input, null, 2);\n}\nreturn {json: {text: text || 'Command executed', chatId: $node['Extract Message'].json.chatId, messageId: $node['Extract Message'].json.messageId}};"
      },
