        "functionCode": "const result = $input.first().json;\nif (!result.result || result.result.length === 0) return null;\nconst update = result.result[0];\nconst msg = update.message;\nif (!msg || !msg.text) return null;\nreturn {json: {text: msg.text, chatId: msg.chat.id, messageId: msg.message_id, updateId: update.update_id}};"
      },
