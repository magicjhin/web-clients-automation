generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Сырьё из RC (только действующие компании Литвы, veikiantis=1).
/// Источник: GET https://get.data.gov.lt/datasets/gov/rc/jar/JuridiniaiAsmenys/:entity
model Company {
  id                 String             @id @default(uuid()) @db.Uuid
  /// RC-код компании (kodas). Upsert-ключ.
  rc_code            String             @unique
  /// Официальное название (pavadinimas).
  name               String
  /// Чистый код EVRK 2-го уровня: "41", "43.2" и т.д.
  /// Извлекается из карты UUID→kodas, а НЕ из числового поля EVRK напрямую.
  evrk2_code         String
  /// Текстовое название EVRK (evrk_2_1_pavadinimas).
  evrk2_name         String
  /// Статус из RC: veikiantis=1 → active. В базу пишем ТОЛЬКО active.
  status             CompanyStatus
  sector             String?
  /// Правовая форма (nuosavybes_forma_pavadinimas).
  legal_form         String?
  address            String?
  city               String?
  /// Дата регистрации (iregistruotas).
  reg_date           DateTime?          @db.Date
  /// Финансовые данные из RC (баланс, прибыль).
  /// АТРИБУТ карточки, НЕ фильтр платёжеспособности — хранить как есть, не анализировать.
  financials         Json?
  /// Когда последний раз синхронизировали из RC.
  rc_synced_at       DateTime?
  created_at         DateTime           @default(now())
  enrichment         Enrichment?
  generated_contents GeneratedContent[]
  lead_deliveries    LeadDelivery[]
  lead_state         LeadState?

  @@index([evrk2_code])
  @@index([status])
  @@index([evrk2_code, status])
  @@map("companies")
}

/// Результаты обогащения компании: Google Places + HTML-верификация + PageSpeed.
/// 1:1 к companies (company_id unique).
model Enrichment {
  id                       String              @id @default(uuid()) @db.Uuid
  /// FK → companies. Уникален: 1:1.
  company_id               String              @unique @db.Uuid
  /// Статус прохождения пайплайна обогащения.
  enrich_status            EnrichStatus        @default(pending)
  /// Итог верификации сайта через HTML-верификацию.
  website_status           WebsiteStatus       @default(not_checked)
  website_url              String?
  /// Есть ли у компании сайт (итог union 3 слоёв: rekvizitai + домен-угадка + поиск).
  has_website              Boolean             @default(false)
  phone                    String?
  /// Второй (мобильный) телефон с карточки rekvizitai.
  mobile                   String?
  /// Контактный email (с сайта компании, /kontaktai). У no-site — обычно пусто (телефонный лид).
  email                    String?
  /// Кредит-риск rekvizitai (Kreditavimo rizika): A..E. ГЛАВНЫЙ фильтр мусора (A/B/C keep, D/E archive).
  credit_risk              CreditRisk?
  /// Исходная подпись риска (Žemiausia/Žema/Vidutinė/Aukšta/Aukščiausia) — для аудита.
  credit_label             String?
  /// Выручка последнего отчётного года (PARDAVIMO PAJAMOS) из API реестра.
  revenue                  Decimal?            @db.Decimal(14, 2)
  /// Чистая прибыль/убыток последнего года (GRYNASIS PELNAS/NUOSTOLIS) из API реестра.
  profit                   Decimal?            @db.Decimal(14, 2)
  /// Год финансовых данных (YYYY).
  fin_year                 Int?
  google_rating            Decimal?            @db.Decimal(3, 1)
  pagespeed_mobile         Int?
  pagespeed_desktop        Int?
  /// Проблемы аудита сайта, найденные при обогащении.
  /// JSON-массив объектов {type, severity, detail}.
  audit_issues             Json?
  /// Ветка лида по итогу анализа: A_bad_site / B_no_site / not_lead.
  lead_branch              LeadBranch?
  enriched_at              DateTime?
  /// Когда перепроверить (динамика — три ведра).
  recheck_at               DateTime?
  /// Сколько Text Search запросов потрачено на эту компанию (макс 1 по правилам).
  places_query_count       Int                 @default(0)
  /// Был ли использован второй запрос (нарушение правила 1 запрос = 1 компания — логировать).
  places_second_query_used Boolean             @default(false)
  /// Уверенность матчинга: high / medium / low.
  places_match_confidence  MatchConfidence?
  /// Числовой скор матчинга (0–100).
  places_match_score       Int?
  /// Детали скоринга: какие поля совпали и с каким весом.
  places_match_reason      Json?
  /// Метод верификации принадлежности сайта.
  verification_method      VerificationMethod?
  /// Статус ревью: high → auto_approved; medium/ambiguous → needs_review.
  review_status            ReviewStatus        @default(needs_review)
  /// Статус очереди аудита: not_requested → queued → running → done/failed.
  /// Кнопка «Запустить аудит» в дашборде выставляет queued; worker audit-gen дренажит очередь.
  audit_status             AuditStatus         @default(not_requested)
  /// Когда оператор поставил лид в очередь аудита.
  audit_requested_at       DateTime?
  /// Когда worker завершил генерацию аудита (done или failed).
  audit_done_at            DateTime?
  company                  Company             @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([audit_status])
  @@map("enrichment")
}

/// Учёт месячного лимита Google Places API (биллинговый месяц = календарный).
/// Перед каждым запросом: проверка used < limit_max. Достигли → skipped_limit, стоп.
model PlacesUsage {
  id         String   @id @default(uuid()) @db.Uuid
  /// Расчётный месяц в формате 'YYYY-MM'. @unique — одна строка на месяц,
  /// чтобы upsert/increment были атомарны и жёсткий стоп 5000/мес нельзя было обойти.
  period     String   @unique
  /// Потрачено запросов в этом месяце.
  used       Int      @default(0)
  /// Жёсткий лимит (5000 по умолчанию = 200€/мес Google бесплатный порог).
  limit_max  Int      @default(5000)
  updated_at DateTime @updatedAt

  @@map("places_usage")
}

/// Динамика компании: три ведра (active_lead / recheck_later / dead).
/// Сайты деградируют — часть «не наших» сами перетекают в «наши» через recheck.
model LeadState {
  company_id  String   @id @db.Uuid
  /// Текущее ведро.
  bucket      Bucket
  last_change DateTime @default(now()) @updatedAt
  company     Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("lead_state")
}

/// Подписчики платформы. На фазе 1 — один subscriber (Aleksandr/Webvibe).
/// Фаза 2: регистрация, тарифы, биллинг, Resend, дедупликация.
model Subscriber {
  id                     String             @id @default(uuid()) @db.Uuid
  email                  String             @unique
  name                   String
  company                String?
  /// Тариф: 1=Лиды, 2=Лиды+Аудит, 3=Под ключ, 4=Максимум (CRM, фаза 3+).
  tier                   Int                @default(1)
  /// API-ключ Resend подписчика (фаза 2 — его домен, его имя в письме).
  resend_api_key         String?
  /// Верифицирован ли домен Resend.
  resend_domain_verified Boolean            @default(false)
  /// Профиль для генерации писем: имя/компания/услуги/тон/портфолио.
  /// Используется LLM для персонализации письма от имени подписчика.
  profile                Json?
  /// Вилка цен подписчика. Влияет на язык аудита и письма.
  price_policy           Json?
  /// Выбранные ниши (EVRK-коды): ["41", "43.2", "68"].
  selected_niches        Json?
  /// Правовая форма: физлицо / ИП / UAB / самозанятый (форма реквизитов).
  legal_form             String?
  status                 SubscriberStatus   @default(trial)
  trial_ends_at          DateTime?
  created_at             DateTime           @default(now())
  generated_contents     GeneratedContent[]
  lead_deliveries        LeadDelivery[]
  subscriptions          Subscription[]
  push_subscriptions     PushSubscription[]

  @@map("subscribers")
}

/// Web Push подписки (PWA, фаза 1). Один subscriber может иметь несколько устройств.
/// Используются для уведомлений (напр. «аудит готов»). VAPID-ключи — из env (src/lib/config).
model PushSubscription {
  id            String     @id @default(uuid()) @db.Uuid
  subscriber_id String     @db.Uuid
  /// Уникальный endpoint браузерного push-сервиса (ключ дедупликации устройства).
  endpoint      String     @unique
  /// Ключи шифрования из PushSubscription.getKey() (base64url).
  p256dh        String
  auth          String
  /// User-Agent устройства (для справки/очистки старых подписок).
  user_agent    String?
  created_at    DateTime   @default(now())
  subscriber    Subscriber @relation(fields: [subscriber_id], references: [id], onDelete: Cascade)

  @@index([subscriber_id])
  @@map("push_subscriptions")
}

/// Выдача лидов подписчику + встроенная дедупликация.
/// blocked_until — лид заблокирован на 1–2 дня после выдачи (при нескольких подписчиках одной ниши).
model LeadDelivery {
  id               String      @id @default(uuid()) @db.Uuid
  subscriber_id    String      @db.Uuid
  company_id       String      @db.Uuid
  delivered_at     DateTime    @default(now())
  /// Дата снятия блокировки дедупликации (1–2 дня после delivered_at).
  blocked_until    DateTime?
  /// Исход лида: sent→in_progress→won/no_response/lost.
  lead_outcome     LeadOutcome @default(sent)
  /// Дата закрытия сделки (won).
  won_at           DateTime?
  /// Сумма сделки в € (статистика ROI).
  deal_value       Decimal?    @db.Decimal(10, 2)
  /// Причина отказа (lost).
  lost_reason      String?
  /// Запланированная дата следующего звонка (источник блока «кому позвонить сегодня»).
  next_call_at     DateTime?
  /// Дата последнего контакта с компанией.
  last_contacted_at DateTime?
  /// Свободная заметка оператора по лиду.
  note             String?
  company          Company     @relation(fields: [company_id], references: [id], onDelete: Cascade)
  subscriber       Subscriber  @relation(fields: [subscriber_id], references: [id], onDelete: Cascade)

  @@index([subscriber_id, company_id])
  @@index([subscriber_id, next_call_at])
  @@index([subscriber_id, lead_outcome])
  @@map("lead_delivery")
}

/// Аудит и письмо, сгенерированные для конкретного лида и подписчика.
/// Фаза 2: Tier 2 — аудит; Tier 3 — аудит + письмо. Перед отправкой — подтверждение человеком (GDPR).
model GeneratedContent {
  id            String        @id @default(uuid()) @db.Uuid
  subscriber_id String        @db.Uuid
  company_id    String        @db.Uuid
  /// Шаблонный аудит сайта (LLM только на Tier 3, иначе шаблон).
  audit_text    String?
  /// Персонализированное письмо на литовском (GPT-4o, фаза 2).
  email_text    String?
  /// draft — сгенерировано; confirmed — подписчик подтвердил; sent — отправлено через Resend.
  status        ContentStatus @default(draft)
  generated_at  DateTime      @default(now())
  sent_at       DateTime?
  company       Company       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  subscriber    Subscriber    @relation(fields: [subscriber_id], references: [id], onDelete: Cascade)

  @@index([subscriber_id, company_id])
  @@map("generated_content")
}

/// Биллинговые подписки (Stripe, активен в фазе 2).
/// На фазе 1 заполняется вручную при seed (один subscriber, tier=1).
model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  subscriber_id      String             @db.Uuid
  /// Тариф подписки (дублирует subscriber.tier для аудита).
  tier               Int
  status             SubscriptionStatus @default(trialing)
  /// Конец текущего оплаченного периода (Stripe current_period_end).
  current_period_end DateTime?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  subscriber         Subscriber         @relation(fields: [subscriber_id], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

/// Статус действующей компании в RC.
/// veikiantis=1 → active. Качаем ТОЛЬКО active.
enum CompanyStatus {
  active
  inactive
  unknown
}

/// Статус обогащения компании через Google Places.
enum EnrichStatus {
  pending
  places_done
  fallback_done
  /// Обогащение через rekvizitai по коду завершено (основной путь LT B2B).
  rekvizitai_done
  /// Мусор по кредит-риску (D/E): НЕ удаляем, помечаем — воркер их пропускает (не прогоняем повторно).
  archived_garbage
  /// Исчерпан месячный лимит 5000 запросов Places — ждём следующего месяца.
  skipped_limit
}

/// Итог верификации сайта: принадлежит ли сайт этой компании.
enum WebsiteStatus {
  not_checked
  candidate_found
  verified_own_website
  no_own_website
  external_profile_only
  ambiguous
  wrong_match
  /// Places не вернул ни одного кандидата для данной компании.
  not_in_places
}

/// Уверенность матчинга Places: high → auto_approved; medium/ambiguous → needs_review; low → не выдавать.
enum MatchConfidence {
  high
  medium
  low
}

/// Метод верификации принадлежности сайта компании.
enum VerificationMethod {
  rc_code_on_site
  phone_match
  address_match
  strong_name_city_match
  manual_review
  none
}

/// Статус ревью обогащённой записи перед выдачей лида.
/// high confidence → auto_approved; medium/ambiguous → needs_review.
enum ReviewStatus {
  auto_approved
  needs_review
  manually_approved
  rejected
}

/// Кредит-риск компании (rekvizitai «Kreditavimo rizika»). Шкала A→E.
/// A=Žemiausia (самый низкий риск) … E=Aukščiausia (наивысший). Решение: A/B/C keep, D/E archive.
/// unknown — карточка без блока риска (нет финотчётности/новая компания).
enum CreditRisk {
  A
  B
  C
  D
  E
  unknown
}

/// Ветка лида по результату обогащения.
/// A_bad_site — сайт есть, но плохой; B_no_site — сайта нет.
enum LeadBranch {
  A_bad_site
  B_no_site
  not_lead
}

/// Ведро динамики: три состояния «жизни» компании в базе.
enum Bucket {
  /// Лид активен — подаётся подписчику.
  active_lead
  /// Сайт норм, перепроверить через N месяцев.
  recheck_later
  /// Компания закрыта / навсегда неактуальна.
  dead
}

/// Статус подписчика платформы.
enum SubscriberStatus {
  active
  trial
  paused
  cancelled
}

/// Статус аудита/письма в generated_content.
enum ContentStatus {
  draft
  confirmed
  sent
}

/// Исход лида (CRM-упрощение, фаза 1 — личная статистика).
enum LeadOutcome {
  sent
  in_progress
  won
  no_response
  lost
}

/// Статус очереди генерации аудита сайта (worker audit-gen).
/// not_requested → queued (кнопка дашборда) → running (воркер взял в работу) → done/failed.
enum AuditStatus {
  not_requested
  queued
  running
  done
  failed
}

/// Статус биллинговой подписки (фаза 2).
enum SubscriptionStatus {
  active
  trialing
  past_due
  cancelled
}
