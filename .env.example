# ─────────────────────────────────────────────────────────
# Leadgen LT — .env.example
# Скопируй в .env и заполни значения.
# .env НЕ коммитится (в .gitignore). Этот файл — в git (без значений).
# ─────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
# Пароль для PostgreSQL (используется в docker-compose.yml и DATABASE_URL)
POSTGRES_PASSWORD=

# Prisma / приложение подключаются по этому URL.
# В Docker: postgres — имя сервиса из docker-compose.yml.
# Локально (без Docker): postgresql://leadgen:<password>@localhost:5432/leadgen
DATABASE_URL=postgresql://leadgen:<password>@postgres:5432/leadgen

# ── Google APIs ──────────────────────────────────────────
# Google Places API — обогащение компаний (лимит 5000 запросов/мес)
GOOGLE_PLACES_API_KEY=

# Google PageSpeed Insights API
PAGESPEED_API_KEY=

# ── Email (Resend) ───────────────────────────────────────
# Resend.com — отправка писем с домена webvibe.lt
# Прогрев домена с первого письма: SPF/DKIM должны быть верифицированы
RESEND_API_KEY=

# ── LLM ──────────────────────────────────────────────────
# OpenAI GPT-4o — генерация аудитов и писем на литовском
OPENAI_API_KEY=

# Claude (опционально — fallback или A/B тест стоимости)
ANTHROPIC_API_KEY=

# ── Auth (NextAuth.js) ───────────────────────────────────
# Случайная строка >= 32 символов: openssl rand -hex 32
AUTH_SECRET=

# Google OAuth2 — вход в дашборд
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Web Push (PWA) ───────────────────────────────────────
# Генерация: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Dashboard password gate ──────────────────────────────
# Password for the simple dashboard auth (no Auth.js needed for Phase 1).
# Must be non-empty — login is denied if this var is unset/empty.
# Generate: openssl rand -base64 24
DASHBOARD_PASSWORD=

# ── App ──────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
NEXT_PUBLIC_APP_URL=http://localhost:3000
